{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": [
    "standard"
  ],
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "script"
  },
  "rules": {
    "no-unused-vars": ["warn", {"args": "none"}],
    "no-console": "off",
    "semi": ["error", "always"],
    "quotes": ["error", "single", {"avoidEscape": true}]
  }
}
